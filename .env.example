# Alpaca API (paper trading by default — set ALPACA_PAPER=false for live)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER=true

# Risk / Capital
ACCOUNT_RISK_PCT=0.01          # 1% of account risk per trade
MAX_POSITIONS=5
MAX_DAILY_LOSS_PCT=0.03        # halt trading if down 3% on the day

# Notifications (optional)
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
